OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# Optional pricing for cost estimates in the OpenAI logs tab.
# Set either the generic values below or model-specific values like:
# OPENAI_PRICE_GPT_5_4_INPUT_PER_1M=
# OPENAI_PRICE_GPT_5_4_OUTPUT_PER_1M=
OPENAI_PRICE_INPUT_PER_1M=
OPENAI_PRICE_OUTPUT_PER_1M=
OPENAI_PRICE_CACHED_INPUT_PER_1M=
OPENAI_PRICE_REASONING_OUTPUT_PER_1M=

# Extension API base URL used by the browser extension config sync
EXTENSION_API_BASE_URL=http://127.0.0.1:8010
EXTENSION_API_HOST=127.0.0.1
EXTENSION_API_PORT=8010
EXTENSION_API_ALLOW_ORIGINS=*
