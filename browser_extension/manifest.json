{
  "manifest_version": 3,
  "name": "TailorResume Companion",
  "version": "1.0.0",
  "description": "User extension UI for TailorResume jobs, resumes, and weekly reports.",
  "action": {
    "default_title": "TailorResume",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "downloads"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
